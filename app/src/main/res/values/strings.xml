<resources>
    <string name="app_name">ScrollStop</string>
    <string name="accessibility_service_description">ScrollStop monitors Instagram, YouTube, and TikTok to detect short-form video feeds (Reels, Shorts, TikToks) and blocks them to help you avoid doomscrolling. Your data never leaves your device.</string>

    <!-- Onboarding -->
    <string name="onboarding_welcome_title">Take Control of Your Scrolling</string>
    <string name="onboarding_welcome_description">ScrollStop detects and blocks Reels, Shorts, and TikToks before you fall into the doomscroll trap.</string>
    <string name="onboarding_how_it_works_title">How It Works</string>
    <string name="onboarding_how_step1">We use Android\'s Accessibility Service to watch for short-form video feeds</string>
    <string name="onboarding_how_step2">When detected, we immediately navigate you away and show a reminder</string>
    <string name="onboarding_how_step3">Your data never leaves your device</string>
    <string name="onboarding_permission_title">Enable Accessibility Service</string>
    <string name="onboarding_permission_description">This is the only way to detect content inside other apps. We never read your messages, passwords, or personal data.</string>
    <string name="onboarding_permission_button">Enable Accessibility Service</string>
