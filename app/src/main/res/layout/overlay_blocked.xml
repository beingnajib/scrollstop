<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#CC000000"
    android:clickable="true"
    android:focusable="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="32dp">

        <ImageView
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:src="@android:drawable/ic_dialog_alert"
            android:contentDescription="Blocked"
            android:layout_marginBottom="16dp" />

        <TextView
            android:id="@+id/blocked_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/blocked_title"
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/blocked_app_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#CCCCCC"
            android:textSize="16sp"
            android:layout_marginBottom="32dp" />

        <Button
            android:id="@+id/btn_dismiss"
            android:layout_width="200dp"
            android:layout_height="48dp"
            android:text="@string/btn_dismiss"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btn_allow_temporary"
            android:layout_width="200dp"
            android:layout_height="48dp"
            android:text="@string/btn_allow_temporary"
            style="@android:style/Widget.Material.Button.Borderless" />

    </LinearLayout>

</FrameLayout>
